# Public backend REST base URL used by API client modules.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public backend WebSocket URL used by the signaling service.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Optional fallback STUN/TURN hint before the backend provides relay credentials.
NEXT_PUBLIC_TURN_PUBLIC_IP=127.0.0.1
