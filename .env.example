# meet37 environment template
#
# Copy this file to .env before running the project locally or in Docker.
# Never commit real production secrets. Replace every placeholder secret below.

# Backend HTTP port inside the backend container/process.
# Local Docker Compose maps this same port on the host by default.
PORT=8080

# Backend HTTP port exposed on the Docker host.
# Behind Caddy/Nginx this can stay internal-only, but local compose publishes it.
BACKEND_HOST_PORT=8080

# Backend healthcheck URL used inside the backend container.
BACKEND_HEALTHCHECK_URL=http://localhost:8080/health

# Runtime environment for the backend.
# Use production for deployed servers. Use development only for local debugging.
ENV=production

# Initial admin account used by the backend auth endpoints.
# Change ADMIN_PASSWORD before exposing the app.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# Secret used to sign access and refresh JWTs.
# Use a long random value in production, for example:
# openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret

# Application access mode.
# public: anonymous users can create/join rooms.
# private: room creation and protected admin/user flows require authentication.
DEFAULT_APP_MODE=public

# Public IP address or DNS name advertised in WebRTC/SFU ICE candidates and
# TURN-style credentials. On a real server, prefer the public IPv4 address if
# clients cannot reliably resolve or reach the domain for UDP media traffic.
TURN_PUBLIC_IP=127.0.0.1

# Comma-separated HTTP endpoints used by scripts/check_server_requirements.py
# to discover the server public IPv4 when --public-ip is not provided.
PUBLIC_IP_DISCOVERY_URLS=https://ifconfig.me,https://icanhazip.com,https://api.ipify.org

# TURN/SFU advertised port.
# If you run a real TURN server such as coturn, it should listen on this port.
# This project also uses the value when returning ICE server metadata to clients.
TURN_PORT=3478

# TURN/SFU port published on the Docker host.
# Keep this equal to TURN_PORT unless another service already uses that port.
TURN_HOST_PORT=3478

# Public relay UDP port range used by coturn for relayed WebRTC traffic.
# These ports must be published by Docker and allowed by the server firewall.
# Increase the range for more concurrent relayed participants.
TURN_RELAY_PORT_MIN=43000
TURN_RELAY_PORT_MAX=43500

# TURN authentication realm. In production use the public meeting domain.
TURN_REALM=localhost

# Shared secret for time-limited TURN-style credentials.
# If coturn is added, configure coturn static-auth-secret with this same value.
TURN_SECRET=another_random_secret_for_turn

# SQLite database path used by the backend.
# In Docker this should point inside the mounted persistent data volume.
DB_PATH=/data/meet.db

# Comma-separated list of allowed browser origins for CORS and WebSocket access.
# Use the exact public HTTPS origin in production, for example:
# ALLOWED_ORIGINS=https://meet.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Access token lifetime in minutes.
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=30

# Per-IP request rate limit.
# RATE_LIMIT_RPS is sustained requests per second; RATE_LIMIT_BURST is the
# short spike allowance.
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=60

# Maximum accepted HTTP request body size in bytes.
# 1048576 equals 1 MiB.
MAX_BODY_BYTES=1048576

# Enables raw RTP recording in the backend SFU relay.
# Recordings are diagnostic RTP dumps, not directly playable media files.
SFU_RECORDING_ENABLED=false
SFU_RECORDING_PATH=/data/recordings

# UDP port range used by Pion WebRTC/SFU media sockets.
# These ports must be published by Docker and allowed by the server firewall.
# Increase the range for more concurrent SFU/media sockets.
WEBRTC_UDP_PORT_MIN=40000
WEBRTC_UDP_PORT_MAX=40500

# UDP port range published on the Docker host.
# Keep this equal to WEBRTC_UDP_PORT_MIN/MAX for production media reliability.
WEBRTC_UDP_HOST_PORT_MIN=40000
WEBRTC_UDP_HOST_PORT_MAX=40500

# Optional Redis URL for multi-instance signaling coordination.
# Leave empty for single-instance deployments.
# Example: redis://redis:6379/0
REDIS_URL=

# Optional instance identifier for clustered deployments.
# Leave empty to use the container/host name.
INSTANCE_ID=

# Public API base URL used by the frontend.
# browser-origin means the browser calls /api on the same origin that served
# the frontend, which is the right value behind Caddy/Nginx reverse proxies.
NEXT_PUBLIC_API_BASE_URL=browser-origin

# Frontend port exposed on the Docker host for local/direct access.
# Reverse-proxy deployments can leave this unpublished in their own compose file,
# but the default compose publishes it for quick testing.
FRONTEND_HOST_PORT=3000

# Frontend HTTP port inside the frontend container/process.
FRONTEND_PORT=3000

# Frontend healthcheck URL used inside the frontend container.
FRONTEND_HEALTHCHECK_URL=http://127.0.0.1:3000/

# Public WebSocket URL used by the frontend.
# browser-origin means the browser connects to /ws on the same origin.
NEXT_PUBLIC_WS_URL=browser-origin

# Public TURN/SFU host exposed to the browser bundle.
# For deployed servers, set this to the same reachable value as TURN_PUBLIC_IP.
NEXT_PUBLIC_TURN_PUBLIC_IP=127.0.0.1

# Internal backend URL used by the production Next.js server for rewrites.
# In Docker Compose this should point at the backend service/container name.
BACKEND_INTERNAL_URL=http://backend:8080

# Docker image names used by scripts/build_docker_images.py.
# For GitHub Container Registry use full names such as:
# ghcr.io/your-org/meet37-backend
DOCKER_BACKEND_IMAGE=meet37-backend
DOCKER_FRONTEND_IMAGE=meet37-frontend
DOCKER_IMAGE_OUTPUT_DIR=dist

# Optional Docker image tag override.
# Leave empty to let scripts/build_docker_images.py use the current git short SHA.
DOCKER_IMAGE_TAG=

# Production container and network names used by docker-compose.prod.yml.
BACKEND_CONTAINER_NAME=meet37-backend
FRONTEND_CONTAINER_NAME=meet37
COTURN_CONTAINER_NAME=meet37-coturn
COTURN_IMAGE=coturn/coturn:latest
# Comma-separated additional third-party images to pull and archive with
# scripts/build_docker_images.py. COTURN_IMAGE is always included separately.
DOCKER_EXTRA_IMAGES=
DOCKER_INTERNAL_NETWORK=meet37_internal
DOCKER_PROXY_NETWORK=proxy
